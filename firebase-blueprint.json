{
  "entities": {
    "VotingSession": {
      "title": "Voting Session",
      "description": "A session for voting on the best performer of a matchday.",
      "type": "object",
      "properties": {
        "matchday": { "type": "number", "description": "The matchday this session is for." },
        "startTime": { "type": "string", "format": "date-time", "description": "When the voting started." },
        "endTime": { "type": "string", "format": "date-time", "description": "When the voting ends (12 hours after start)." },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "fcName": { "type": "string" }
            }
          },
          "description": "The 4 gamers nominated for best performance."
        },
        "isActive": { "type": "boolean", "description": "Whether the session is currently active." }
      },
      "required": ["matchday", "startTime", "endTime", "candidates", "isActive"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A single vote cast by a user.",
      "type": "object",
      "properties": {
        "voterId": { "type": "string", "description": "The persistent browser ID of the voter." },
        "candidateId": { "type": "string", "description": "The ID of the gamer being voted for." },
        "matchday": { "type": "number", "description": "The matchday this vote is for." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the vote was cast." },
        "ip": { "type": "string", "description": "The IP address of the voter for tracking." }
      },
      "required": ["voterId", "candidateId", "matchday", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email", "role"]
    },
    "News": {
      "title": "News",
      "description": "News article about matchdays.",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "title": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["topic", "date", "title", "description"]
    },
    "BracketMatch": {
      "title": "Bracket Match",
      "description": "A match in the tournament bracket.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "round": { "type": "string" },
        "homeTeamName": { "type": "string" },
        "awayTeamName": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" }
      },
      "required": ["id", "round", "homeTeamName", "awayTeamName"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "visitCount": { "type": "number", "description": "Total number of page visits." }
      },
      "required": ["visitCount"]
    },
    "InterestedStats": {
      "title": "Interested Stats",
      "description": "Statistics for users interested in future events.",
      "type": "object",
      "properties": {
        "interestedCount": { "type": "number", "description": "Total number of interested users." }
      },
      "required": ["interestedCount"]
    }
  },
  "firestore": {
    "/votingSessions/{sessionId}": {
      "schema": "VotingSession",
      "description": "Collection of voting sessions."
    },
    "/votes/{voteId}": {
      "schema": "Vote",
      "description": "Collection of individual votes."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/news/{newsId}": {
      "schema": "News",
      "description": "Collection of news articles."
    },
    "/bracket/{matchId}": {
      "schema": "BracketMatch",
      "description": "Collection of bracket matches."
    },
    "/stats/global": {
      "schema": "GlobalStats",
      "description": "Global statistics document."
    },
    "/stats/may_event": {
      "schema": "InterestedStats",
      "description": "Statistics for the May event interest."
    }
  }
}
