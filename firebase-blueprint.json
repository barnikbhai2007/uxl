{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "User registration for the tournament.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "age": { "type": "number" },
        "fcUid": { "type": "string" },
        "fcName": { "type": "string" },
        "teamOvr": { "type": "number" },
        "experience": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "age", "fcUid", "fcName", "teamOvr", "experience", "timestamp"]
    },
    "Config": {
      "title": "Config",
      "description": "System configuration.",
      "type": "object",
      "properties": {
        "registrationEnabled": { "type": "boolean" },
        "geminiApiKey": { "type": "string" },
        "geminiModel": { "type": "string" }
      },
      "required": ["registrationEnabled"]
    },
    "User": {
      "title": "User",
      "description": "User profile and role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "achievements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "achievementId": { "type": "string" },
              "unlockedAt": { "type": "string", "format": "date-time" },
              "seen": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["uid", "email", "role"]
    },
    "BracketMatch": {
      "title": "Bracket Match",
      "description": "A match in the tournament bracket.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "round": { "type": "string" },
        "homeTeamName": { "type": "string" },
        "awayTeamName": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" }
      },
      "required": ["id", "round", "homeTeamName", "awayTeamName"]
    },
    "GlobalStats": {
      "title": "Global Stats",
      "description": "Global statistics for the application.",
      "type": "object",
      "properties": {
        "visitCount": { "type": "number", "description": "Total number of page visits." }
      },
      "required": ["visitCount"]
    },
    "Match": {
      "title": "Match",
      "description": "A tournament match fixture.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "homeTeamId": { "type": "string" },
        "awayTeamId": { "type": "string" },
        "homeScore": { "type": "number" },
        "awayScore": { "type": "number" },
        "status": { "type": "string", "enum": ["upcoming", "live", "finished", "rescheduled"] },
        "date": { "type": "string" },
        "matchNumber": { "type": "number" }
      },
      "required": ["id", "homeTeamId", "awayTeamId", "status", "date", "matchNumber"]
    },
    "CMSContent": {
      "title": "CMS Content",
      "description": "Editable text content for the website.",
      "type": "object",
      "properties": {
        "text": { "type": "string" }
      },
      "required": ["text"]
    }
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of user registrations."
    },
    "/config/system": {
      "schema": "Config",
      "description": "System configuration document."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    },
    "/bracket/{matchId}": {
      "schema": "BracketMatch",
      "description": "Collection of bracket matches."
    },
    "/stats/global": {
      "schema": "GlobalStats",
      "description": "Global statistics document."
    },
    "/matches/{matchId}": {
      "schema": "Match",
      "description": "Collection of match fixtures."
    },
    "/content/{contentId}": {
      "schema": "CMSContent",
      "description": "Collection of editable text content."
    }
  }
}
