rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: registrations
    // Document ID: {registrationId}
    // Fields:
    //   - userId: string (required)
    //   - name: string (required)
    //   - age: number (required)
    //   - fcUid: string (required)
    //   - fcName: string (required)
    //   - teamOvr: number (required)
    //   - experience: string (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: config
    // Document ID: system
    // Fields:
    //   - registrationEnabled: bool (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: bracket
    // Document ID: {matchId}
    // Fields:
    //   - id: string (required)
    //   - round: string (required)
    //   - homeTeamName: string (required)
    //   - awayTeamName: string (required)
    //   - homeScore: number (optional)
    //   - awayScore: number (optional)
    //
    // Collection: stats
    // Document ID: global
    // Fields:
    //   - visitCount: number (for global)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "webblogger82@gmail.com" ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin")
      );
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidBracketMatch(data) {
      return data.keys().hasAll(['id', 'round', 'homeTeamName', 'awayTeamName']) &&
             data.id is string &&
             data.round is string &&
             data.homeTeamName is string &&
             data.awayTeamName is string &&
             (!('homeScore' in data) || data.homeScore is number) &&
             (!('awayScore' in data) || data.awayScore is number);
    }

    function isValidRegistration(data) {
      return data.keys().hasAll(['userId', 'fcName', 'fcUid', 'name', 'status', 'timestamp', 'age', 'teamOvr', 'experience']) &&
             data.userId == request.auth.uid &&
             data.name is string &&
             data.fcUid is string &&
             data.fcName is string &&
             data.status in ['pending', 'approved', 'rejected'] &&
             // Removed strict equality check on server time to allow serverTimestamp() to process
             data.age is number &&
             data.teamOvr is number &&
             data.experience is string;
    }

    function isValidMatch(data) {
      return (!('id' in data) || data.id is string) &&
             (!('homeTeamId' in data) || data.homeTeamId is string) &&
             (!('awayTeamId' in data) || data.awayTeamId is string) &&
             (!('status' in data) || data.status in ['scheduled', 'upcoming', 'live', 'ongoing', 'finished', 'rescheduled', 'postponed']) &&
             (!('date' in data) || data.date is string) &&
             (!('matchNumber' in data) || data.matchNumber is number);
    }

    function isValidMatchCreate(data) {
      return data.keys().hasAll(['id', 'homeTeamId', 'awayTeamId', 'status', 'date', 'matchNumber']) &&
             isValidMatch(data);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /registrations/{registrationId} {
      allow get: if isAdmin() || isOwner(registrationId);
      allow list: if isAdmin() || (resource.data.status == 'approved');
      allow create: if isAuthenticated() && isValidRegistration(request.resource.data);
      allow update, delete: if isAdmin();
    }

    match /site_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /config/system {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /config/qualification {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bracket/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBracketMatch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow create: if isAdmin() && isValidMatchCreate(request.resource.data);
      allow update: if (
        isAdmin() || 
        (isAuthenticated() && (request.auth.uid == resource.data.homeTeamId || request.auth.uid == resource.data.awayTeamId))
      ) && isValidMatch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /match_labels/{date} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /stats/{statId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if true;
    }
  }
}
