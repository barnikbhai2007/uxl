rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: votingSessions
    // Document ID: matchday-{number}
    // Fields:
    //   - id: string (required)
    //   - sessionId: string (required)
    //   - matchday: number (required)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp (required)
    //   - candidates: list (required)
    //   - isActive: bool (required)
    //
    // Collection: votes
    // Document ID: {voterId}_{sessionId}
    // Fields:
    //   - voterId: string (required)
    //   - userId: string (required)
    //   - candidateId: string (required)
    //   - matchday: number (required)
    //   - sessionId: string (required)
    //   - timestamp: timestamp (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'user')
    //
    // Collection: news
    // Document ID: {newsId}
    // Fields:
    //   - topic: string (required)
    //   - date: string (required)
    //   - title: string (required)
    //   - description: string (required)
    //
    // Collection: bracket
    // Document ID: {matchId}
    // Fields:
    //   - id: string (required)
    //   - round: string (required)
    //   - homeTeamName: string (required)
    //   - awayTeamName: string (required)
    //   - homeScore: number (optional)
    //   - awayScore: number (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "webblogger82@gmail.com" && request.auth.token.email_verified == true));
    }

    function isVotingOpen(sessionDocId) {
      return exists(/databases/$(database)/documents/votingSessions/$(sessionDocId)) && 
             get(/databases/$(database)/documents/votingSessions/$(sessionDocId)).data.isActive == true &&
             (get(/databases/$(database)/documents/votingSessions/$(sessionDocId)).data.endTime == null || 
              request.time <= get(/databases/$(database)/documents/votingSessions/$(sessionDocId)).data.endTime);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'];
    }

    function isValidVote(data) {
      return data.keys().hasAll(['voterId', 'userId', 'candidateId', 'matchday', 'sessionId', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.candidateId is string &&
             (data.matchday is number || data.matchday is string) &&
             data.sessionId is string;
    }

    function isValidBracketMatch(data) {
      return data.keys().hasAll(['id', 'round', 'homeTeamName', 'awayTeamName']) &&
             data.id is string &&
             data.round is string &&
             data.homeTeamName is string &&
             data.awayTeamName is string &&
             (!('homeScore' in data) || data.homeScore is number) &&
             (!('awayScore' in data) || data.awayScore is number);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isAdmin();
    }

    match /votingSessions/{sessionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /votes/{voteId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                      isValidVote(request.resource.data) && 
                      isVotingOpen(request.resource.data.get('sessionDocId', request.resource.data.sessionId));
      allow update, delete: if false;
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /bracket/{matchId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBracketMatch(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
